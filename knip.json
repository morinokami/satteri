{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["crates/**", "packages/satteri/bench/fixtures/**"],
  "workspaces": {
    "packages/satteri": {
      "entry": ["bench/**/*.{ts,mjs}", "test/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@emnapi/core",
        "@emnapi/runtime",
        "@napi-rs/wasm-runtime",
        "mdast-util-mdx"
      ]
    },
    "examples": {
      "entry": ["*.ts"]
    },
    "packages/vite-plugin-satteri/example": {
      "entry": ["src/**/*.{ts,tsx,mdx}"]
    },
    "website": {
      "entry": ["assets/**/*.{ts,css}"],
      "ignoreDependencies": ["@tailwindcss/cli", "wrangler"],
      "ignoreBinaries": ["maudit"]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
